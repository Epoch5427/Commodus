{
    "id" : "io.github.Epoch5427.Commodus",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "command" : "commodus",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "blueprint-compiler",
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://gitlab.gnome.org/GNOME/blueprint-compiler.git",
                    "branch" : "main",
                    "depth" : 1
                }
            ]
        },
        {
            "name" : "commodus",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "dir",
                    "path" : "."
                }
            ]
        }
    ]
}
